# Phantom Frame — WebSocket collaboration server (Pôle 1)
# Referenced by the Streamix docker-compose.yml as `ws-server`.
# Build context = repo root.
FROM node:20-alpine

WORKDIR /app

# Install only the server dependencies (ws).
COPY server/package*.json ./server/
RUN cd server && npm install --omit=dev

# App source.
COPY server ./server

ENV PORT=8080
EXPOSE 8080

CMD ["node", "server/index.js"]
