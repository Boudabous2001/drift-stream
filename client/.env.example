# Phantom Frame — variables client (copier en client/.env)
# Toutes optionnelles : sans elles, l'app fonctionne en autonome (WS via proxy).

# Serveur WebSocket de collaboration (Pôle 1)
VITE_WS_URL=ws://localhost:8080

# --- Intégration Streamix ---
# Flux HLS chiffré AES-128 (Pôle 2 — Nginx)
VITE_HLS_BASE_URL=http://localhost:8001
# Serveur de clés éphémères (Pôle 2)
VITE_KEY_SERVER_URL=http://localhost:8085
# Token d'accès à la clé AES
VITE_HLS_TOKEN=token_cyber_2026
# Pipeline IA Whisper + Gemini (Pôle 3)
VITE_AI_API_URL=http://localhost:8000
